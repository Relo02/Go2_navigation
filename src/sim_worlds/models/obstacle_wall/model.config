<?xml version="1.0"?>
<model>
  <name>obstacle_wall</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>
  <description>
    2.00 × 0.10 × 0.80 m wall segment obstacle.
    Spawn at z=0.40 to rest on ground plane.
    Rotate around Z-axis to orient the wall direction.
